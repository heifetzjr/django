##verificar versão
poetry --version

##criar ou usar projeto existente
poetry new nome-do-projeto
poetry init

##ativar
poetry env activate

##instalar
poetry add nome-do-pacote

##instalar django
poetry add django

##verificar se django foi instalado corretamente
poetry run django-admin --version

##criar um projeto django
poetry run django-admin startproject config .

#config é o nome do projeto (você pode trocar, ex.: meuprojeto)
#. diz para criar os arquivos na pasta atual (sem subpasta extra)
